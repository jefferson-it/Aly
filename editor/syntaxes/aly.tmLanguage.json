{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aly",
  "scopeName": "source.aly",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#properties" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.aly",
          "begin": "##",
          "end": "##"
        },
        {
          "name": "comment.line.number-sign.aly",
          "begin": "#",
          "end": "$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aly",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.aly",
              "match": "\\\\."
            },
            {
              "name": "variable.interpolation.aly",
              "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*"
            }
          ]
        },
        {
          "name": "string.quoted.single.aly",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.aly",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.aly",
          "match": "\\b(if|elif|else|try|catch|return|async|await|loop|do|match|import|export|new)\\b"
        },
        {
          "name": "storage.type.aly",
          "match": "\\b(let|const|fun|struct|model|tomb|schema)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.aly",
          "match": "(?i:\\b(and|or|xor|not)\\b)"
        },
        {
          "name": "keyword.operator.comparison.aly",
          "match": "(?i:\\b(eq|neq|lt|lte|gt|gte)\\b)"
        },
        {
          "name": "keyword.operator.assignment.aly",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.aly",
          "match": "=>"
        },
        {
          "name": "keyword.operator.range.aly",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.arithmetic.aly",
          "match": "(\\+|\\-|\\*|/|%|\\|)"
        },
        {
          "name": "keyword.operator.pointer.aly",
          "match": "&"
        },
        {
          "name": "variable.language.this.aly",
          "match": "@"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.aly",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.none.aly",
          "match": "\\bNone\\b"
        },
        {
          "name": "variable.language.anonymous.aly",
          "match": "\\b_\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.percent.aly",
          "match": "\\b\\d+(\\.\\d+)?%"
        },
        {
          "name": "constant.numeric.float.aly",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.aly",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.builtin.aly",
          "match": "\\b(print|input|pow|sqrt|random|round|roundUp|roundDown|to_fixed)\\b\\s*(?=\\()"
        },
        {
          "name": "support.class.namespace.aly",
          "match": "\\b(fs|str|sys|http)\\b(?=\\.)"
        },
        {
          "name": "entity.name.function.aly",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b\\s*(?=\\()"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "variable.other.object.aly",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\.)"
        },
        {
          "name": "variable.other.property.aly",
          "match": "(?<=\\.)\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.aly",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
