# Test loop keyword (only loop, no for/while)

# Simple counter with break
let i = 0
loop {
    i += 1
    if i eq 5 {
        break
    }
}
print("i after loop = $i")
print("Assert: 5")

# Test continue
let j = 0
let result = ""
loop {
    j += 1
    if j eq 3 {
        continue
    }
    result = result + j
    if j eq 5 {
        break
    }
}
print("result after continue loop = $result")
